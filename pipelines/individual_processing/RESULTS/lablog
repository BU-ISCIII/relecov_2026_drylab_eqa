ln -s /data/ucct/bi/research/EQA_RELECOV_2026/influenza_reference_numbering/* influenza_reference_numbering

# User-generated files

ANALYSIS_RP=$( realpath ../ANALYSIS )
COD_LAB=$( pwd | cut -d '/' -f8 )

rm -r variants_long_table/ consensus_files/ validated_metadata.json
mkdir variants_long_table
mkdir consensus_files 
ln -s $ANALYSIS_RP/variant_long_table/* variants_long_table/
ln -s $ANALYSIS_RP/00-consensus/* consensus_files/
ln -s $( realpath ../RAW/validated*json ) validated_metadata.json

