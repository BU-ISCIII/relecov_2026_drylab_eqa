# Gold standard files
mkdir gold_standard
mkdir gold_standard/variants_long_table
mkdir gold_standard/consensus
mkdir influenza_reference_numbering

ln -s $( realpath /data/ucct/bi/research/EQA_RELECOV_2026/gold_standards_relecov/vcf/* ) gold_standard/variants_long_table/
